# Database
DATABASE_URL=postgresql://cognentrz_user:cognentrz_pass@localhost:5432/cognentrz_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cognentrz_db
POSTGRES_USER=cognentrz_user
POSTGRES_PASSWORD=cognentrz_pass

# Auth
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
NEXTAUTH_SECRET=another_long_random_secret
NEXTAUTH_URL=http://localhost:3000

# Google Earth Engine (already configured via backend/credentials/earth-engine-key.json)
GEE_SERVICE_ACCOUNT=cognentrz@cognentrz-499116.iam.gserviceaccount.com
GEE_PROJECT_ID=cognentrz-499116
GEE_KEY_FILE=./backend/credentials/earth-engine-key.json

# Weather API - Get free key at openweathermap.org
OPENWEATHER_API_KEY=your_openweather_api_key_here

# AI Recommendations - Get free key at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  # Optional alternative

# Maps (Optional - uses OpenStreetMap satellite by default)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Razorpay (Pro subscription payments) — get keys at dashboard.razorpay.com
# Leave blank to run the upgrade flow in DEMO mode (no real charge)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# WhatsApp alerts (Twilio) — leave blank for demo mode
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Google Translate (regional languages) — leave blank to use free fallback
GOOGLE_TRANSLATE_API_KEY=

# CallMeBot — free REAL WhatsApp to your own number (see WhatsApp Alerts page for setup)
CALLMEBOT_APIKEY=
