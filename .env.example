# ─────────────────────────────────────────────────────────────────────────────
# Cognentrz — Environment Variables
# Copy this file to .env.local for local dev.
# Add ALL of these to Vercel → Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Neon) ──────────────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/cognentrz?sslmode=require

# ── Auth (generate a long random string) ────────────────────────────────────
JWT_SECRET=replace_with_at_least_32_random_characters_here
NEXTAUTH_SECRET=another_long_random_secret_here
NEXTAUTH_URL=https://your-app.vercel.app

# ── Google Earth Engine ──────────────────────────────────────────────────────
# Project ID from Google Cloud Console
GEE_PROJECT_ID=cognentrz-499116
GEE_SERVICE_ACCOUNT=cognentrz@cognentrz-499116.iam.gserviceaccount.com

# IMPORTANT for Vercel: paste the ENTIRE contents of earth-engine-key.json
# as a single line (JSON.stringify it first if needed — it must be valid JSON).
# In Vercel dashboard, set this as a Secret environment variable.
GEE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# ── Weather API ──────────────────────────────────────────────────────────────
# Free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ── AI (Google Gemini) ───────────────────────────────────────────────────────
# Free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ── Razorpay Payments (optional — leave blank for demo mode) ─────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── WhatsApp Alerts (optional — leave blank for demo mode) ──────────────────
# Option A: Twilio (recommended)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Option B: CallMeBot (free, activate at callmebot.com/blog/free-whatsapp-api)
CALLMEBOT_APIKEY=

# ── Google Translate (optional — free fallback used if blank) ────────────────
GOOGLE_TRANSLATE_API_KEY=

# ── SoilGrids (public API, no key needed) ───────────────────────────────────
SOILGRIDS_BASE_URL=https://rest.isric.org/soilgrids/v2.0
